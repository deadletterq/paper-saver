# --- Bot ---
# Token from @BotFather on Telegram. Only this is pushed to the Pi.
TELEGRAM_BOT_TOKEN=your_token_here

# --- Deploy target (only used by scripts/deploy.sh, never pushed) ---
RPI_HOST=raspberrypi.local
RPI_USER=pi
RPI_PASSWORD=changeme
# Optional. Defaults to /home/${RPI_USER}/paper-saver-bot.
# RPI_REMOTE_DIR=/home/pi/paper-saver-bot
