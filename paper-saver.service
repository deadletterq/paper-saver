[Unit]
Description=Paper-Saver Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/paper-saver-bot
EnvironmentFile=/home/pi/paper-saver-bot/.env
ExecStart=/home/pi/paper-saver-bot/.venv/bin/python bot.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
